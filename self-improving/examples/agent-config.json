{
  "name": "your-agent",
  "model": "claude-sonnet",

  "resources": [
    "file://<REPO_ROOT>/self-improving/SKILL.md"
  ],

  "hooks": {
    "agentSpawn": [
      {
        "command": "bash <REPO_ROOT>/hooks/dispatch.sh agent-spawn",
        "description": "Load context, memory, and review check"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "bash <REPO_ROOT>/hooks/dispatch.sh user-prompt-submit",
        "description": "Inject proactive-agent and capture-check"
      }
    ],
    "preToolUse": [
      {
        "command": "bash <REPO_ROOT>/hooks/dispatch.sh pre-tool-use",
        "description": "Pre-tool validation"
      }
    ],
    "postToolUse": [
      {
        "command": "bash <REPO_ROOT>/hooks/dispatch.sh post-tool-use",
        "description": "Auto-log tool errors"
      }
    ],
    "stop": [
      {
        "command": "bash <REPO_ROOT>/hooks/dispatch.sh stop",
        "description": "Session review prompt"
      }
    ]
  }
}
